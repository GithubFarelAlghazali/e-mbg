<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: linear-gradient(to bottom right, #E8F5E9, #E0F2F1);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.embg.app.controllers.LoginController">
    <stylesheets>
        <URL value="@/styles/baseauth.css" />
    </stylesheets>
   <children>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="380.0" spacing="16.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 15, 0, 0, 5);">
         <padding>
            <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
         </padding>
         <children>
            <StackPane maxHeight="44.0" maxWidth="44.0" prefHeight="44.0" prefWidth="44.0" style="-fx-background-color: #E8F5E9; -fx-background-radius: 10;">
               <children>
                  <Text fill="#22C55E" strokeType="OUTSIDE" strokeWidth="0.0" text="🍴">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Text>
               </children>
               <VBox.margin>
                  <Insets top="4.0" />
               </VBox.margin>
            </StackPane>
            <VBox alignment="CENTER" spacing="6.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sign in to MBG" textAlignment="CENTER">
                     <font>
                        <Font name="Poppins Bold" size="24.0" />
                     </font>
                  </Text>
                  <Text fill="#6B7280" strokeType="OUTSIDE" strokeWidth="0.0" text="Makan Bergizi Gratis Management Portal" textAlignment="CENTER">
                     <font>
                        <Font name="Poppins Regular" size="12.0" />
                     </font>
                  </Text>
               </children>
               <VBox.margin>
                  <Insets bottom="8.0" />
               </VBox.margin>
            </VBox>
            <VBox alignment="CENTER_LEFT" spacing="6.0">
               <children>
                  <Text fill="#374151" strokeType="OUTSIDE" strokeWidth="0.0" text="Email Address">
                     <font>
                        <Font name="Poppins Medium" size="12.0" />
                     </font>
                  </Text>
                  <TextField fx:id="emailField" prefHeight="40.0" promptText="admin@mbg.gov.id" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12 0 12;">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                     <font>
                        <Font name="Poppins Regular" size="13.0" />
                     </font>
                  </TextField>
               </children>
            </VBox>
            <VBox alignment="CENTER_LEFT" spacing="6.0">
               <children>
                  <Text fill="#374151" strokeType="OUTSIDE" strokeWidth="0.0" text="Password">
                     <font>
                        <Font name="Poppins Medium" size="12.0" />
                     </font>
                  </Text>
                  <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="••••••••" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12 0 12;" />
               </children>
            </VBox>
            <HBox alignment="CENTER_LEFT" prefWidth="200.0">
               <children>
                  <CheckBox fx:id="rememberMeCheckbox" mnemonicParsing="false" text="Remember me" textFill="#4B5563">
                     <font>
                        <Font name="Poppins Regular" size="12.0" />
                     </font>
                  </CheckBox>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword" text="Forgot password?" textFill="#22C55E">
                           <font>
                              <Font name="Poppins SemiBold" size="12.0" />
                           </font>
                        </Hyperlink>
                     </children>
                  </HBox>
               </children>
            </HBox>
            <Button fx:id="signInButton" mnemonicParsing="false" onAction="#handleSignIn" prefHeight="42.0" prefWidth="320.0" style="-fx-background-color: #22C55E; -fx-background-radius: 8;" text="Sign in →" textFill="WHITE">
               <font>
                  <Font name="Poppins SemiBold" size="14.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Button>
            <Line endX="215.0" stroke="#E5E7EB" strokeWidth="0.8">
               <VBox.margin>
                  <Insets bottom="4.0" top="8.0" />
               </VBox.margin>
            </Line>
            <HBox alignment="CENTER" spacing="4.0">
               <children>
                  <Text fill="#4B5563" strokeType="OUTSIDE" strokeWidth="0.0" text="Don't have an account?">
                     <font>
                        <Font name="Poppins Regular" size="12.0" />
                     </font>
                  </Text>
                  <Hyperlink fx:id="registerLink" onAction="#handleRegister" text="Register" textFill="#15803D">
                     <font>
                        <Font name="Poppins Bold" size="12.0" />
                     </font>
                  </Hyperlink>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>