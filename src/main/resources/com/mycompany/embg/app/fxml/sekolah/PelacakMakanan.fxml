<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane style="-fx-background-color: #f0f4f8; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.embg.app.controllers.sekolah.PelacakMakananKontroler">
    
    <left>
        <VBox prefWidth="220.0" spacing="5.0" style="-fx-background-color: #ffffff; -fx-border-color: transparent #e2e8f0 transparent transparent; -fx-border-width: 1;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <padding><Insets bottom="25.0" left="15.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 12; -fx-background-radius: 8; -fx-font-size: 16;" text="M" />
                        <VBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #006b3f;" text="Sistem MBG" />
                            <Label style="-fx-font-size: 11; -fx-text-fill: #64748b;" text="Portal Sekolah" />
                        </VBox>
                    </children>
                </HBox>

                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#clickDashboard" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 13; -fx-padding: 12 15 12 20; -fx-cursor: hand;" text="■  Dasbor" />
                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#clickSiswa" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 13; -fx-padding: 12 15 12 20; -fx-cursor: hand;" text="👥  Siswa" />
                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#clickDistribusi" style="-fx-background-color: #dcfce7; -fx-text-fill: #006b3f; -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 12 15 12 20; -fx-border-color: #22c55e; -fx-border-width: 0 0 0 4; -fx-cursor: hand;" text="🍴  Pelacak Makanan" />
                <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#clickProfil" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 13; -fx-padding: 12 15 12 20; -fx-cursor: hand;" text="🎓  Profil Sekolah" />
                
                <Region VBox.vgrow="ALWAYS" />
                
                <VBox spacing="10">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" /></padding>
                    <children>
                        <Button maxWidth="Infinity" style="-fx-background-color: #006b3f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;" text="📥 Ekspor Laporan" />
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 13; -fx-padding: 10 15; -fx-cursor: hand;" text="⚙  Pengaturan" />
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 13; -fx-padding: 10 15; -fx-cursor: hand;" text="🚪  Keluar" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <BorderPane>
            <top>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 15 30; -fx-border-color: transparent transparent #e2e8f0 transparent; -fx-border-width: 1;">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefWidth="300" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-padding: 8 15;">
                            <children>
                                <Label text="🔍" textFill="#94a3b8" />
                                <TextField promptText="Cari..." style="-fx-background-color: transparent; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-size: 18; -fx-text-fill: #475569; -fx-cursor: hand;" text="🔔" />
                        <Label style="-fx-font-size: 18; -fx-text-fill: #475569; -fx-cursor: hand;" text="❓" />
                        <Circle fill="#1e293b" radius="16.0" />
                    </children>
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-control-inner-background: #f0f4f8; -fx-border-color: transparent; -fx-padding: 0;">
                    <content>
                        <VBox spacing="25.0">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="25.0" />
                            </padding>
                            <children>
                                
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="2">
                                            <children>
                                                <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Log Distribusi Pengiriman" />
                                                <Label style="-fx-font-size: 13; -fx-text-fill: #64748b;" text="Lacak dan kelola status pengiriman makanan dari Vendor." />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 5 10;">
                                            <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-weight: bold;" text="&lt;" />
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13;" text="📅 Hari Ini" />
                                            <Button style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-font-weight: bold;" text="&gt;" />
                                        </HBox>
                                    </children>
                                </HBox>

                                <VBox spacing="15" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 3);" VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Tabel Status Pengiriman" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <HBox spacing="10">
                                                <Button onAction="#handleRefresh" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-text-fill: #475569; -fx-padding: 6 12; -fx-font-size: 13; -fx-cursor: hand;" text="🔄 Segarkan Data" />
                                            </HBox>
                                        </HBox>

                                        <TableView fx:id="tblPelacakMakan" prefHeight="400.0" style="-fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-color: transparent; -fx-font-size: 14;">
                                            <columns>
                                                <TableColumn fx:id="colVendor" prefWidth="180.0" text="NAMA VENDOR" />
                                                <TableColumn fx:id="colMenu" prefWidth="250.0" text="MENU MAKANAN" />
                                                <TableColumn fx:id="colPorsi" prefWidth="100.0" text="JUMLAH PORSI" />
                                                <TableColumn fx:id="colTanggal" prefWidth="120.0" text="TANGGAL" />
                                                <TableColumn fx:id="colStatus" prefWidth="150.0" text="STATUS" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                        <!-- Tombol Konfirmasi Penerimaan (hanya sekolah yang bisa klik) -->
                                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                            <Label style="-fx-font-size: 12; -fx-text-fill: #94a3b8; -fx-font-style: italic;"
                                                   text="Pilih baris berstatus 'dikirim', lalu tekan tombol di bawah." />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button onAction="#handleKonfirmasiPenerimaan"
                                                    style="-fx-background-color: #006b3f; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;"
                                                    text="✅  Konfirmasi Diterima" />
                                        </HBox>

                                        </children>
                                </VBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>