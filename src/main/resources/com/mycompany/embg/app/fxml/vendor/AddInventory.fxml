<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.embg.app.controllers.vendor.AddInventoryController"
      spacing="10">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Tambah Barang"/>

    <TextField fx:id="txtNamaBarang"
               promptText="Nama Barang"/>

    <TextField fx:id="txtStok"
               promptText="Stok"/>

    <TextField fx:id="txtSatuan"
               promptText="Satuan"/>
    
    <TextField fx:id="txtHarga"
           promptText="Harga"/>

    <Button text="Simpan"
            onAction="#handleSave"/>

</VBox>