<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.embg.app.controllers.admin.InventoryController"
      style="-fx-background-color:#F8FAFC;">

    <padding>
        <Insets top="28" right="28" bottom="28" left="28"/>
    </padding>

    <Label text="Inventory" style="-fx-font-size:26px; -fx-font-weight:bold;"/>
    <Label text="Manage kitchen stock and food ingredients." style="-fx-text-fill:#64748B;"/>

    <HBox spacing="18">
        <VBox prefWidth="230" spacing="8" style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#BFDBFE; -fx-border-radius:12;">
            <Label text="TOTAL BAHAN"/>
            <Label text="86" style="-fx-font-size:24px; -fx-font-weight:bold;"/>
            <Label text="Aktif" style="-fx-text-fill:#0284C7;"/>
        </VBox>

        <VBox prefWidth="230" spacing="8" style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#BFDBFE; -fx-border-radius:12;">
            <Label text="STOK MENIPIS"/>
            <Label text="12" style="-fx-font-size:24px; -fx-font-weight:bold;"/>
            <Label text="Perlu restock" style="-fx-text-fill:#0284C7;"/>
        </VBox>

        <VBox prefWidth="230" spacing="8" style="-fx-background-color:white; -fx-padding:18; -fx-background-radius:12; -fx-border-color:#BFDBFE; -fx-border-radius:12;">
            <Label text="EXPIRED SOON"/>
            <Label text="5" style="-fx-font-size:24px; -fx-font-weight:bold;"/>
            <Label text="Cek gudang" style="-fx-text-fill:#0284C7;"/>
        </VBox>
    </HBox>

    <TableView fx:id="inventoryTable" prefHeight="360"/>
</VBox>