<VBox spacing="20" style="-fx-background-color:#F8FAFC;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.mycompany.embg.app.controllers.admin.SchoolController">

    <padding>
        <Insets bottom="28" left="28" right="28" top="28" />
    </padding>

    <Label style="-fx-font-size:26px; -fx-font-weight:bold;" text="School Verification" />
    <Label style="-fx-text-fill:#64748B;" text="Review and approve new educational institutions joining the MBG program." />

    <TableView fx:id="schoolTable" prefHeight="360" />
</VBox>
