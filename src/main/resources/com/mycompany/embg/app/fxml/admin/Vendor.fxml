<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mycompany.embg.app.controllers.admin.VendorController"
      style="-fx-background-color: #F8FAFC;">

    <padding>
        <Insets top="28" right="28" bottom="28" left="28"/>
    </padding>

    <Label text="Vendor Verification" style="-fx-font-size:26px; -fx-font-weight:bold;"/>
    <Label text="Review and manage food supplier registrations for the MBG program." style="-fx-text-fill:#64748B;"/>

    <HBox spacing="18">
        </HBox>

    <TableView fx:id="vendorTable" prefHeight="250"/>

    <VBox fx:id="detailPanel" visible="false" spacing="10" style="-fx-background-color: white; -fx-padding: 18; -fx-border-color: #BFDBFE; -fx-border-radius: 12;">
        <Label text="Detail Vendor Terpilih" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
        <GridPane hgap="15" vgap="10">
            <Label text="Nama Vendor:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="detailNama" style="-fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Alamat:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="detailAlamat" style="-fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Status Saat Ini:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label fx:id="detailStatus" style="-fx-font-weight:bold;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
        
        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button text="Verifikasi Dokumen" onAction="#handleVerifikasi" style="-fx-background-color: #0284C7; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

</VBox>